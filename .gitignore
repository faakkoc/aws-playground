# Local .terraform directories
**/.terraform/*

# .tfstate files
*.tfstate
*.tfstate.*.backup

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files, which are likely to contain sensitive data, such as
# password, private keys, and other secrets. These should not be part of version 
# control as they are data points which are potentially sensitive and subject 
# to change depending on the environment.
*.tfvars
*.tfvars.json

# Ignore override files as they are usually used for local testing or sensitive data
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Include tfplan files to ignore the plan output of command, terraform plan -out=tfplan
# example: *tfplan*
*tfplan*

# Ignore .idea directory which is used by JetBrains IDEs for project-specific settings and should not be included in version control
.idea

# Ignore lock.hcl files which are used by Terraform to manage provider dependencies and should not be included in version control
*.lock.hcl

# Ignore .DS_Store files which are created by macOS to store custom attributes of a folder and should not be included in version control
.DS_Store
